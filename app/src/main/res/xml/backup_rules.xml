<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Crisix: E2EE keys, encrypted messages and contact data must never
         leave the device via Android Auto-Backup (security risk).
         Only exclude what we know contains sensitive data. -->
    <exclude domain="database" path="crisix.db" />
    <exclude domain="database" path="crisix.db-wal" />
    <exclude domain="database" path="crisix.db-shm" />
    <exclude domain="sharedpref" path="crisix_contacts.xml" />
    <exclude domain="sharedpref" path="crisix_setup.xml" />
    <exclude domain="sharedpref" path="crisix_update.xml" />
</full-backup-content>
